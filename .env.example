# ==========================================
# 🚀 UNIHUB - PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# --- 1. AI SERVICE ---
LLM_PROVIDER=gemini
LLM_API_KEY=<your-gemini-api-key>
LLM_MODEL=gemini-flash-latest

# --- 2. BACKEND: DATABASE & CACHE ---
DB_URL=jdbc:postgresql://<aws-0-region>.pooler.supabase.com:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=<your-db-password>

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# --- 3. BACKEND: INTEGRATIONS ---
SYNC_STUDENTS_URL=https://<your-project-ref>.supabase.co/storage/v1/object/public/unihub-data/students.csv
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>
AI_SERVICE_URL=http://ai-service:8000

# --- 4. BACKEND: NOTIFICATIONS & MAIL ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email>@gmail.com
MAIL_PASSWORD=<your-email-app-password>

NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
-- Can be any random string, but should be kept secret and unique for your deployment
TELEGRAM_WEBHOOK_TOKEN=<your-telegram-webhook-secret>

# --- 5. BACKEND: SECURITY ---
-- Can be any random string, but should be kept secret and unique for your deployment (32 characters or longer)
JWT_ACCESS_SECRET=<your-jwt-access-secret>
JWT_REFRESH_SECRET=<your-jwt-refresh-secret>

# --- 6. FRONTEND ---
VITE_TELEGRAM_BOT=unihub_workshop_bot