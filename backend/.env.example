REDIS_PORT=6379
REDIS_PASSWORD=


# MAIL CONFIGURATION
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=


# NOTIFICATION CONFIGURATION
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=<telegram_bot_token>
TELEGRAM_WEBHOOK_TOKEN=<your_webhook_token>


# SECURITY CONFIGURATION
# Required: Keys must be at least 32 characters long for HS256 algorithm
JWT_ACCESS_SECRET=Nqdkj3h4g5f6dh2b3c7s8a9wt3y4u5i6o7p8q9z0x1c8e5q4w5r7e
