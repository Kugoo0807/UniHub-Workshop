# APP CONFIGURATION
FRONTEND_URL=http://localhost:5173


# DATABASE CONFIGURATION
# CLOUD CONFIGURATION
DB_URL=jdbc:postgresql://<aws-0-region>.pooler.supabase.com:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=your_secure_password
# CSV CONFIGURATION
